# Copy this file to .env for Docker Compose.

# Required before Odoo API tools can call Odoo.
ODOO_URL=https://your-odoo-host.example.com
ODOO_API_KEY=your-odoo-api-key

# Optional Odoo connection metadata.
ODOO_DATABASE=
ODOO_TIMEOUT_SECONDS=30
ODOO_ALLOWED_GENERIC_METHODS=
ODOO_CRM_OPTIONAL_FEATURES=

# MCP HTTP auth. Use "static" or "jwt" for exposed HTTP deployments.
MCP_AUTH_MODE=none
MCP_STATIC_TOKEN=
JWT_JWKS_URI=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_PUBLIC_KEY=
JWT_REQUIRED_SCOPES=

# FastMCP HTTP runtime defaults used by Docker.
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000
MCP_HTTP_PATH=/mcp
MCP_LOG_LEVEL=info
