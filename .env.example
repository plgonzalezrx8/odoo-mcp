# Copy this file to .env for Docker Compose.

# Required before Odoo API tools can call Odoo.
ODOO_URL=https://your-odoo-host.example.com

# Optional Odoo connection metadata. Exact authentication use is implemented by
# the Odoo client/tool modules.
ODOO_DATABASE=
ODOO_USERNAME=
ODOO_PASSWORD=
ODOO_API_KEY=

# Optional JWT secret if the HTTP runtime is placed behind auth middleware.
JWT_SECRET=

# FastMCP HTTP runtime defaults used by Docker.
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000
MCP_HTTP_PATH=/mcp
MCP_LOG_LEVEL=info
